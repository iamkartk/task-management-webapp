pipeline {
    agent any

    environment {
        PATH = "$PATH:/Applications/Docker.app/Contents/Resources/bin"
        GIT_COMMIT_HASH = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
    }

    stages {
        stage('Build Notification Service'){
            steps {
                script {
                    sh 'cd notification-service && /opt/homebrew/bin/mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image'){
            steps {
                script {
                    sh 'cd notification-service && docker build -t notification-service:${GIT_COMMIT_HASH} .'
                }
            }
        }

        stage('Tag as Latest'){
            steps {
                script {
                    sh 'docker tag notification-service:${GIT_COMMIT_HASH} notification-service:latest'
                }
            }
        }

        stage('Deploy with Docker Compose'){
            steps {
                script {
                    sh """
                    export TAG=${GIT_COMMIT_HASH}
                    docker rm -f notification-service 2>/dev/null || true
                    docker compose stop notification-service 2>/dev/null || true
                    docker compose rm -f notification-service 2>/dev/null || true
                    docker compose up -d --no-deps notification-service
                    """
                }
            }
        }

        stage('Clean up old images'){
            steps {
                script {
                    sh '''
                    docker images notification-service --format "{{.Tag}}" | grep -v latest | sort -r | sed '1,2d' | while read tag; do
                        docker rmi notification-service:$tag 2>/dev/null || true
                    done
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}