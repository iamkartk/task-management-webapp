pipeline {
    agent any

    environment {
        PATH = "$PATH:/Applications/Docker.app/Contents/Resources/bin"
        GIT_COMMIT_HASH = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
    }

    stages {
        stage('Build Maven Project') {
            steps {
                script {
                    sh 'cd eureka-server && /opt/homebrew/bin/mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh 'cd eureka-server && docker build -t eureka-server:${GIT_COMMIT_HASH} .'
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                script {
                    sh """
                    export TAG=${GIT_COMMIT_HASH}
                    cd eureka-server
                    docker compose -f ../docker-compose.yml up -d --no-deps eureka-server
                    """
                }
            }
        }

        stage('Clean up old images') {
            steps {
                script {
                    sh '''
                    # Keep only the 2 most recent images
                    docker images eureka-server --format "{{.Tag}}" | sort -r | sed '1,2d' | while read tag; do
                        docker rmi eureka-server:$tag 2>/dev/null || true
                    done
                    '''
                }
            }
        }
    }
    post { always { cleanWs() } }
}